import tkinter as tk
from tkinter import ttk, messagebox, filedialog
import json
from datetime import datetime

DATA_FILE='expenses.json'

class ExpenseTracker:
    def __init__(self, root):
        self.root=root
        self.root.title('Expense Tracker')
        self.root.geometry('900x600')
        self.data=[]
        self.build_ui()
        self.load_data()

    def build_ui(self):
        frm=tk.Frame(self.root)
        frm.pack(fill='x', padx=10, pady=10)

        tk.Label(frm,text='Сумма').grid(row=0,column=0)
        self.amount=tk.Entry(frm,width=12)
        self.amount.grid(row=0,column=1)

        tk.Label(frm,text='Категория').grid(row=0,column=2)
        self.category=ttk.Combobox(frm,values=['Еда','Транспорт','Развлечения','Жильё','Другое'],width=15)
        self.category.grid(row=0,column=3)
        self.category.set('Еда')

        tk.Label(frm,text='Дата (YYYY-MM-DD)').grid(row=0,column=4)
        self.date=tk.Entry(frm,width=14)
        self.date.grid(row=0,column=5)
        self.date.insert(0, datetime.now().strftime('%Y-%m-%d'))

        tk.Button(frm,text='Добавить расход',command=self.add_expense).grid(row=0,column=6,padx=5)

        filterf=tk.Frame(self.root)
        filterf.pack(fill='x', padx=10)
        tk.Label(filterf,text='Фильтр категория').grid(row=0,column=0)
        self.filter_cat=ttk.Combobox(filterf,values=['Все','Еда','Транспорт','Развлечения','Жильё','Другое'],width=15)
        self.filter_cat.grid(row=0,column=1)
        self.filter_cat.set('Все')

        tk.Label(filterf,text='От').grid(row=0,column=2)
        self.from_date=tk.Entry(filterf,width=12)
        self.from_date.grid(row=0,column=3)
        tk.Label(filterf,text='До').grid(row=0,column=4)
        self.to_date=tk.Entry(filterf,width=12)
        self.to_date.grid(row=0,column=5)
        tk.Button(filterf,text='Применить фильтр',command=self.refresh_table).grid(row=0,column=6,padx=5)
        tk.Button(filterf,text='Сумма за период',command=self.calc_sum).grid(row=0,column=7,padx=5)

        self.total_lbl=tk.Label(self.root,text='Итого: 0')
        self.total_lbl.pack(anchor='w', padx=10, pady=5)

        cols=('amount','category','date')
        self.tree=ttk.Treeview(self.root,columns=cols,show='headings')
        for c,t in zip(cols,['Сумма','Категория','Дата']):
            self.tree.heading(c,text=t)
        self.tree.pack(fill='both', expand=True, padx=10, pady=10)

        bottom=tk.Frame(self.root)
        bottom.pack(fill='x', padx=10, pady=5)
        tk.Button(bottom,text='Сохранить JSON',command=self.save_data).pack(side='left')
        tk.Button(bottom,text='Загрузить JSON',command=self.load_data).pack(side='left', padx=5)

    def validate(self, amount, date_text):
        try:
            amount=float(amount)
            if amount<=0:
                raise ValueError
        except:
            messagebox.showerror('Ошибка','Сумма должна быть положительным числом')
            return None
        try:
            datetime.strptime(date_text,'%Y-%m-%d')
        except:
            messagebox.showerror('Ошибка','Дата должна быть в формате YYYY-MM-DD')
            return None
        return amount

    def add_expense(self):
        amount=self.validate(self.amount.get(), self.date.get())
        if amount is None:
            return
        item={'amount':amount,'category':self.category.get(),'date':self.date.get()}
        self.data.append(item)
        self.refresh_table()
        self.save_data()

    def filtered(self):
        items=self.data[:]
        cat=self.filter_cat.get()
        if cat and cat!='Все':
            items=[i for i in items if i['category']==cat]
        fd=self.from_date.get().strip()
        td=self.to_date.get().strip()
        if fd:
            items=[i for i in items if i['date']>=fd]
        if td:
            items=[i for i in items if i['date']<=td]
        return items

    def refresh_table(self):
        for row in self.tree.get_children():
            self.tree.delete(row)
        for i in self.filtered():
            self.tree.insert('', 'end', values=(i['amount'], i['category'], i['date']))
        self.calc_sum(update_only=True)

    def calc_sum(self, update_only=False):
        total=sum(i['amount'] for i in self.filtered())
        self.total_lbl.config(text=f'Итого: {total:.2f}')
        if not update_only:
            messagebox.showinfo('Сумма', f'Расходы за период: {total:.2f}')

    def save_data(self):
        with open(DATA_FILE,'w',encoding='utf-8') as f:
            json.dump(self.data,f,ensure_ascii=False,indent=2)

    def load_data(self):
        try:
            with open(DATA_FILE,'r',encoding='utf-8') as f:
                self.data=json.load(f)
        except:
            self.data=[]
        self.refresh_table()

root=tk.Tk()
app=ExpenseTracker(root)
root.mainloop()
